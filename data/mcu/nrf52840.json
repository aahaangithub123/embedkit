  "passiveCircuits": [
    {
      "label": "VDD Decoupling",
      "why": "The nRF52840 draws sharp current spikes during radio TX bursts (~100ns rise time). Without local decoupling, these spikes cause VDD to droop, which corrupts radio timing and can trigger the brownout detector.",
      "components": [
        { "type": "capacitor", "value": "100nF", "spec": "X5R ceramic, 10V", "placement": "VDD pin, trace <0.5mm" },
        { "type": "capacitor", "value": "10µF", "spec": "X5R ceramic, 10V", "placement": "Module power rail, within 5mm" }
      ]
    },
    {
      "label": "DCDC Enable",
      "why": "The MDBT50Q module uses an internal DC-DC converter that achieves 80% efficiency vs 55% for LDO mode. This reduces active current by ~30%. Requires L1 (10µH) on the DEC4 pin.",
      "components": [
        { "type": "inductor", "value": "10µH", "spec": "≥150mA, DCR<0.5Ω, Murata LQH3NPN100", "placement": "DEC4 pin to DCCH pin, <5mm loop area" }
      ]
    }
  ],
