  "passiveCircuits": [
    {
      "label": "RF Matching Network",
      "why": "The SX1262 output impedance is 50Ω differential. The matching network transforms this to 50Ω single-ended for the antenna port. Wrong values detune the PA and reduce range by 10dB+.",
      "components": [
        { "type": "inductor", "value": "3.9nH", "spec": "0402 RF, Q>30 at 900MHz", "placement": "RFO pin, within 2mm" },
        { "type": "capacitor", "value": "8.2pF", "spec": "C0G/NP0 ceramic, 50V", "placement": "Shunt to GND after inductor" }
      ]
    },
    {
      "label": "VBAT Decoupling",
      "why": "LoRa TX at 22dBm draws 118mA in <1µs pulses. VBAT must be rock-solid during TX or the frequency drifts mid-packet, causing receiver CRC failures.",
      "components": [
        { "type": "capacitor", "value": "100µF", "spec": "Electrolytic or polymer, 10V", "placement": "VBAT pin, within 5mm" },
        { "type": "capacitor", "value": "100nF", "spec": "X5R ceramic 10V", "placement": "VBAT pin, trace <0.5mm" }
      ]
    },
    {
      "label": "TXCO Supply Filter",
      "why": "The SX1262 TXCO output must be clean. Noise on DIO3 (used as TCXO supply) causes frequency error on the transmitted carrier.",
      "components": [
        { "type": "capacitor", "value": "100nF", "spec": "X5R ceramic 10V", "placement": "DIO3 to GND, TCXO supply pin" }
      ]
    }
  ],
